<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.flicklist.scrobbler" name="FlickList Scrobbler" version="1.0.4" provider-name="FlickList">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.31.0"/>
    </requires>
    <extension point="xbmc.service" library="service.py"/>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <summary lang="en">FlickList Scrobbler for Kodi</summary>
        <description lang="en">Automatically track what you watch in Kodi with FlickList. Works with any video addon.</description>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
